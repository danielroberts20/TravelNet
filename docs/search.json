---
layout: none
---
[
  {% assign pages = site.pages | where_exp: "p", "p.layout == 'doc'" %}
  {% for page in pages %}
  {
    "url":     "{{ page.url | relative_url }}",
    "title":   {{ page.title | jsonify }},
    "section": {{ page.section | default: "" | jsonify }},
    "content": {{ page.content | strip_html | strip_newlines | truncate: 2000 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
